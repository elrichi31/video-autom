{
  "name": "video-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "free-port": "node scripts/free-port.mjs 3001",
    "predev": "npm run free-port && npm run clean",
    "dev": "next dev -p 3001",
    "prebuild": "npm run clean",
    "build": "next build",
    "start": "next start -p 3001"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.47.0",
    "@remotion/player": "^4.0.440",
    "next": "14.2.29",
    "openai": "^4.97.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.440"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
